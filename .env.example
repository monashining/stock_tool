# 複製此檔為 .env 並填入實際值
# cp .env.example .env

# LINE 推播（選填，未設定時推播功能會停用）
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_MULTI_ULTRA_SHOW_CATEGORY=0

# SQLite（方案 B）
# 預設為 data/stock_tool.db，不填也可
SQLITE_PATH=data/stock_tool.db
# 是否寫入 query_log（1=true；0=false）
SQLITE_LOG_ENABLED=1
